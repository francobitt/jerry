{
  "backend": "lmstudio",
  "model": "qwen3-coder:30b",
  "max_steps": 20,
  "headless": false,
  "use_vision": "false",
  "flash_mode": true,

  "session_file": null,

  "save_artifacts": true,
  "save_gif": true,
